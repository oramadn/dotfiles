 {
    "layer": "top",
    "position": "top",
    "padding-top": 20,
    "height": 37,
    "modules-left": ["custom/power"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["clock"],

    "hyprland/workspaces": {
        "format": " ",
        "all-outputs": true,
        "on-click": "hyprctl dispatch workspace {name}",
    },
    "clock": {
    	"format": "{:%I:%M %p}",
    	"tooltip": false
    },
    "custom/power": {
        "format": "⏻",
        "tooltip": false
    }
} 

